function BuildEquationMatrix(A, B)
    F := BaseRing(A);
    d := Nrows(A);
    rows := [];

    // Unknown vector position n represents one X entry.
    // We build equations for A*X - X*B = 0.
    // Initial indexing assumes row-major:
    //   pos(i,j) = (i-1)*d + j.
    for i in [1..d] do
        for j in [1..d] do
            row := [F!0 : n in [1..d*d]];

            for a in [1..d] do
                idx := (a-1)*d + j;
                row[idx] +:= A[i,a];
            end for;

            for b in [1..d] do
                idx := (i-1)*d + b;
                row[idx] -:= B[b,j];
            end for;

            Append(~rows, row);
        end for;
    end for;

    return Matrix(F, rows);
end function;

function MatFromVec_RowMajor(v, d, F)
    s := Eltseq(v);
    return Matrix(F, d, d, [s[(i-1)*d + j] : i in [1..d], j in [1..d]]);
end function;

function MatFromVec_ColMajor(v, d, F)
    s := Eltseq(v);
    return Matrix(F, d, d, [s[(j-1)*d + i] : i in [1..d], j in [1..d]]);
end function;

function CountGoodBasis(V, mode, A, B, d, F)
    bas := Basis(V);
    good := 0;
    tested := Minimum(10, #bas);

    for r in [1..tested] do
        if mode eq "row" then
            X := MatFromVec_RowMajor(bas[r], d, F);
        else
            X := MatFromVec_ColMajor(bas[r], d, F);
        end if;

        if A*X eq X*B then
            good +:= 1;
        end if;
    end for;

    return good, tested;
end function;

