// STEP 1: Build genuine F4(7) in Magma and find g of order 13
//         with trace 0 on the 26-dimensional module.
//
// New strategy:
//   Work in genuine Magma F4(7) on V26 first.
//   First target: find g with Order(g)=13 and Trace(g)=0.
//   Do NOT use Normalizer or IsConjugate in this step.
///////////////////////////////////////////////////////////////

SetSeed(1);

F := GF(7);

function SignedGF7(a)
    a := F!a;
    if a eq F!0 then
        return 0;
    elif a eq F!1 then
        return 1;
    elif a eq F!2 then
        return 2;
    elif a eq F!3 then
        return 3;
    elif a eq F!4 then
        return -3;
    elif a eq F!5 then
        return -2;
    elif a eq F!6 then
        return -1;
    end if;
end function;

print "============================================================";
print "STEP 1: BUILD GENUINE F4(7) AND FIND ORDER-13 TRACE-0 g";
print "============================================================";

print "Building G := ChevalleyGroup(\"F\",4,GF(7))...";
G := ChevalleyGroup("F", 4, F);

print "Basic checks:";
print "Base ring =", BaseRing(G);
print "Degree =", Degree(G);
print "Number of generators =", Ngens(G);
print "Factored order of G =";
print FactoredOrder(G);

print "";
print "Generator checks on V26:";
for i in [1..Ngens(G)] do
    x := G.i;
    print "Generator", i;
    print "  Order =", Order(x);
    print "  Trace =", SignedGF7(Trace(x));
    print "  Trace powers [x,x^2,x^3] =",
        [SignedGF7(Trace(x^j)) : j in [1..3]];
end for;

print "";
print "Random search for g with Order(g)=13 and Trace(g)=0...";

found := false;
maxTrials := 300;

for trial in [1..maxTrials] do

    x := Random(G);
    ox := Order(x);

    if ox mod 13 eq 0 then

        gCandidate := x^(ox div 13);

        if Order(gCandidate) eq 13 then

            tr := Trace(gCandidate);

            if tr eq F!0 then
                g := gCandidate;
                found := true;

                print "";
                print "SUCCESS: found g.";
                print "Trial =", trial;
                print "Original random element order =", ox;
                print "Order(g) =", Order(g);
                print "Trace(g) =", SignedGF7(Trace(g));
                print "Trace(g^i), i=1..12 =",
                    [SignedGF7(Trace(g^i)) : i in [1..12]];

                break;
            end if;
        end if;
    end if;

    if trial mod 25 eq 0 then
        print "  trials done =", trial;
    end if;
end for;

if not found then
    print "";
    print "NO g found within", maxTrials, "trials.";
    print "This is not a mathematical failure. Increase maxTrials and rerun.";
else
    print "";
    print "STEP 1 COMPLETE.";
    print "We now have g of order 13 with trace 0 on V26.";
    print "Next step will search for f of order 6 with g^f = g^k, k != 1, ideally k = 10.";
