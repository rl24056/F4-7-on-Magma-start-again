function TransporterSpaceDim(A, B)
    // Computes dimension of the solution space:
    //     A X = X B
    // for X a d x d matrix over F.
    F := BaseRing(A);
    d := Nrows(A);

    rows := [];

    // Unknowns are X_{i,j}, ordered by (i,j)
    for i in [1..d] do
        for j in [1..d] do

            // Equation for entry (i,j) of A X - X B = 0
            row := [F!0 : n in [1..d*d]];

            // (A X)_{i,j} = sum_a A_{i,a} X_{a,j}
            for a in [1..d] do
                idx := (a-1)*d + j;
                row[idx] +:= A[i,a];
            end for;

            // (X B)_{i,j} = sum_b X_{i,b} B_{b,j}
            for b in [1..d] do
                idx := (i-1)*d + b;
                row[idx] -:= B[b,j];
            end for;

            Append(~rows, row);
        end for;
    end for;

    L := Matrix(F, rows);
    K := Nullspace(L);

    return Dimension(K), K;
end function;

