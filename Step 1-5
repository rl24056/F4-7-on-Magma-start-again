                            print "    Order(Y) =", Order(Y);
                            print "    A*Y = Y*B ?", A*Y eq Y*B;
                            print "    Trace profile Y =", TraceProfileMat26(Y);

                            if A*Y eq Y*B and Order(Y) eq 6 and TraceProfileMat26(Y) eq [1,-1,-2] then

                                print "";
                                print "SUCCESS: found GL f-like order-6 power!";
                                print "Y^-1*g*Y = g^10 ?", Y^-1*A*Y eq B;
                                print "Order(Y) =", Order(Y);
                                print "Trace profile [Y,Y^2,Y^3] =", TraceProfileMat26(Y);

                                fGL5A := Y;
                                goodPowerCount +:= 1;
                                break;
                            end if;
                        end if;
                    end for;
                end if;
            end if;
        end if;
    end if;

    if goodPowerCount gt 0 then
        break;
    end if;

    if trial mod 500 eq 0 then
        print "  samples =", trial,
              " invertible =", invertibleCount,
              " targetTrace =", targetTraceCount,
              " orderTests =", orderTests,
              " powerCandidates =", powerCandidatesTested;
    end if;

    if orderTests ge maxOrderTests5A and targetTraceCount ge maxOrderTests5A then
        print "";
        print "Reached maxOrderTests5A =", maxOrderTests5A;
        break;
    end if;

end for;

print "";
print "STEP 5A SUMMARY:";
print "Samples =", sampleCount;
print "Invertible transporters =", invertibleCount;
print "Target-trace transporters =", targetTraceCount;
print "Target-trace order tests =", orderTests;
print "Power candidates tested =", powerCandidatesTested;
print "Good GL order-6 powers found =", goodPowerCount;

if goodPowerCount gt 0 then
    print "";
    print "STEP 5A RESULT:";
    print "We found fGL5A in GL26 with:";
    print "  fGL5A^-1*g*fGL5A = g^10";
    print "  Order(fGL5A)=6";
    print "  Trace profile [1,-1,-2]";
    print "Next step: test whether it preserves F4 structure / invariant forms.";
else
    print "";
    print "STEP 5A RESULT:";
    print "No order-6 power was found from the tested target-trace transporters.";
    print "Then random GL transporters are probably not enough.";
    print "Next step should impose extra structure, for example invariant bilinear/cubic form constraints.";
end if;
