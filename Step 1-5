function PowerExponentInG(g, y)
    // Return k if y = g^k for k = 0,...,12.
    // Return -1 if y is not in <g>.
    for k in [0..12] do
        if y eq g^k then
            return k;
        end if;
    end for;
    return -1;
end function;

function ActionExponentOnP(g, x)
    // Computes exponent k such that g^x = g^k.
    // In Magma, g^x means x^-1*g*x.
    y := g^x;
    return PowerExponentInG(g, y);
end function;

