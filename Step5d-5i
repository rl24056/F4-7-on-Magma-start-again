F := GF(7);

function SignedGF7(a)
    a := F!a;
    if a eq F!0 then
        return 0;
    elif a eq F!1 then
        return 1;
    elif a eq F!2 then
        return 2;
    elif a eq F!3 then
        return 3;
    elif a eq F!4 then
        return -3;
    elif a eq F!5 then
        return -2;
    elif a eq F!6 then
        return -1;
    end if;
end function;

function TraceProfile(M)
    return [SignedGF7(Trace(M^i)) : i in [1..3]];
end function;

function BlockDiag2(F, B1, B2)
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    M := ZeroMatrix(F, n1+n2, n1+n2);

    for i in [1..n1] do
        for j in [1..n1] do
            M[i,j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n1+i,n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

function BlockDiag3(F, B0, B1, B2)
    n0 := Nrows(B0);
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    M := ZeroMatrix(F, n0+n1+n2, n0+n1+n2);

    for i in [1..n0] do
        for j in [1..n0] do
            M[i,j] := B0[i,j];
        end for;
    end for;

    for i in [1..n1] do
        for j in [1..n1] do
            M[n0+i,n0+j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n0+n1+i,n0+n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

function Block2x2(F, B11, B12, B21, B22)
    n := Nrows(B11);
    M := ZeroMatrix(F, 2*n, 2*n);

    for i in [1..n] do
        for j in [1..n] do
            M[i,j] := B11[i,j];
            M[i,n+j] := B12[i,j];
            M[n+i,j] := B21[i,j];
            M[n+i,n+j] := B22[i,j];
        end for;
    end for;

    return M;
end function;

///////////////////////////////////////////////////////////////
// Transporter space for C*X = X*D^10
///////////////////////////////////////////////////////////////

function BuildEquationMatrix(C, B)
    F := BaseRing(C);
    n := Nrows(C);
    rows := [];

    for i in [1..n] do
        for j in [1..n] do
            row := [F!0 : k in [1..n*n]];

            for a in [1..n] do
                idx := (a-1)*n + j;
                row[idx] +:= C[i,a];
            end for;

            for b in [1..n] do
                idx := (i-1)*n + b;
                row[idx] -:= B[b,j];
            end for;

            Append(~rows, row);
        end for;
    end for;

    return Matrix(F, rows);
end function;

function MatFromVec_ColMajor(v, n, F)
    s := Eltseq(v);
    return Matrix(F, n, n, [s[(j-1)*n + i] : i in [1..n], j in [1..n]]);
end function;

function TransporterSpace(C, D)
    // Solve C*X = X*D^10
    B := D^10;
    L := BuildEquationMatrix(C, B);

    // Same convention fixed in Step 4B:
    // Nullspace(Transpose(L)) + column-major.
    return Nullspace(Transpose(L));
end function;

function FindInvertibleTransporter(C, D, label)
    F := BaseRing(C);
    n := Nrows(C);

    K := TransporterSpace(C, D);
    bas := Basis(K);

    print "";
    print "Transporter", label;
    print "  dimension =", Dimension(K);

    // Try basis vectors first
    for r in [1..#bas] do
        X := MatFromVec_ColMajor(bas[r], n, F);
        if C*X eq X*D^10 and Rank(X) eq n then
            print "  found invertible basis transporter at basis", r;
            return X;
        end if;
    end for;

    // Try random linear combinations
    for trial in [1..500] do
        v := K!0;

        for r in [1..#bas] do
            c := Random(F);
            if c ne F!0 then
                v +:= c*bas[r];
            end if;
        end for;

        X := MatFromVec_ColMajor(v, n, F);

        if C*X eq X*D^10 and Rank(X) eq n then
            print "  found invertible random transporter at trial", trial;
            return X;
        end if;
    end for;

    error "Failed to find invertible transporter for " cat label;
end function;

