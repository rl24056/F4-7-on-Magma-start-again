///////////////////////////////////////////////////////////////

print "";
print "============================================================";
print "STEP 5E: TEST fGL AGAINST F4-INVARIANT BILINEAR FORM";
print "============================================================";

if not assigned G then
    error "G is not assigned. Run Step 5D first.";
end if;

if not assigned A then
    error "A is not assigned. Run Step 5D first.";
end if;

if not assigned fGL then
    error "fGL is not assigned. Run Step 5D first.";
end if;

F := GF(7);
d := Degree(G);

function MatFromVec_RowMajor(v, d, F)
    s := Eltseq(v);
    return Matrix(F, d, d, [s[(i-1)*d + j] : i in [1..d], j in [1..d]]);
end function;

function InvariantBilinearFormSpace(mats, F, d)
    rows := [];

    for M in mats do
        for i in [1..d] do
            for j in [1..d] do

                row := [F!0 : n in [1..d*d]];

                // Equation:
                //   (M*S*Transpose(M))_{i,j} - S_{i,j} = 0
                //
                // Coefficient of S[a,b] is M[i,a]*M[j,b].
                for a in [1..d] do
                    for b in [1..d] do
                        idx := (a-1)*d + b;
                        row[idx] +:= M[i,a] * M[j,b];
                    end for;
                end for;

                // subtract S[i,j]
                idx0 := (i-1)*d + j;
                row[idx0] -:= F!1;

                Append(~rows, row);
            end for;
        end for;
    end for;

    L := Matrix(F, rows);

    // Right nullspace convention, as in transporter fix.
    return Nullspace(Transpose(L));
end function;

function ScalarMultipleInfo(X, Y, F)
    // Return <true, lambda> if X = lambda*Y.
    for lambda in F do
        if X eq lambda * Y then
            return true, lambda;
        end if;
    end for;

    return false, F!0;
end function;

print "Degree =", d;
print "Computing invariant bilinear forms for genuine F4 generators...";

gens := [Matrix(G.i) : i in [1..Ngens(G)]];

Kbil := InvariantBilinearFormSpace(gens, F, d);
Bbil := Basis(Kbil);

print "Dimension of invariant bilinear form space =", Dimension(Kbil);

if Dimension(Kbil) eq 0 then
    error "No invariant bilinear form found. Something is wrong.";
end if;

print "";
print "Ranks of basis invariant forms:";

bestRank := -1;
bestIndex := 0;
Sbest := ZeroMatrix(F, d, d);

for r in [1..#Bbil] do
    S := MatFromVec_RowMajor(Bbil[r], d, F);
    rk := Rank(S);
    print "  basis form", r, "rank =", rk;

    if rk gt bestRank then
        bestRank := rk;
        bestIndex := r;
        Sbest := S;
    end if;
end for;

print "";
print "Best basis form index =", bestIndex;
print "Best rank =", bestRank;

if bestRank lt d then
    print "Best basis form is singular. Trying random combinations...";

    for trial in [1..200] do
        v := Kbil!0;

        for i in [1..#Bbil] do
            c := Random(F);
            if c ne F!0 then
                v +:= c * Bbil[i];
            end if;
        end for;

        S := MatFromVec_RowMajor(v, d, F);
        rk := Rank(S);

        if rk gt bestRank then
            bestRank := rk;
            Sbest := S;
            print "  improved rank at trial", trial, "rank =", rk;
        end if;

        if rk eq d then
            break;
        end if;
    end for;
end if;

print "";
print "Final selected invariant form rank =", Rank(Sbest);

print "";
print "Sanity check: genuine generators preserve Sbest exactly:";
for i in [1..Ngens(G)] do
    M := Matrix(G.i);
    print "  Generator", i, "preserves Sbest?",
        M*Sbest*Transpose(M) eq Sbest;
end for;

print "";
print "Check g preserves Sbest:";
print "  A*Sbest*Transpose(A) = Sbest ?",
    A*Sbest*Transpose(A) eq Sbest;

print "";
print "Now test fGL:";

Sf := fGL*Sbest*Transpose(fGL);

exactPreserve := Sf eq Sbest;
isScalar, lambda := ScalarMultipleInfo(Sf, Sbest, F);

print "  fGL*Sbest*Transpose(fGL) = Sbest ?", exactPreserve;
print "  fGL preserves Sbest up to scalar?", isScalar;
print "  scalar lambda =", lambda;

print "";
print "STEP 5E SUMMARY:";

if exactPreserve then
    print "GOOD: fGL preserves the F4-invariant bilinear form exactly.";
    print "This is only a necessary test, not full F4 membership.";
    print "Next step: test stronger F4 minimal-module structure, likely cubic/Albert invariant.";
elif isScalar then
    print "PARTIAL: fGL preserves the form only up to scalar.";
    print "This suggests fGL is in a conformal group, but probably not genuine F4(7).";
    print "Next step: adjust the 2D fixed block or impose exact invariant constraints.";
else
    print "FAIL: fGL does not preserve the genuine F4-invariant bilinear form.";
    print "Therefore this controlled GL f is not an element of genuine F4(7).";
    print "Next step: rebuild the 2D fixed block / transporter with invariant-form constraints included.";
end if;
