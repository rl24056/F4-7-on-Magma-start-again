///////////////////////////////////////////////////////////////
// STEP 5D ALL-IN-ONE:
// Build controlled GL order-6 transporter in clean 2+12+12 basis.
//
// We rebuild:
//   G = F4(7) on V26
//   g order 13 trace 0
//   clean adapted basis V26 = 2 + 12 + 12
//
// Then construct f blockwise:
//   fixed 2D block: diag(3,5), order 6, trace profile [1,-1,-2]
//   each 12D block: Frobenius transporter C -> C^10
//
// Goal:
//   fGL^-1 * g * fGL = g^10
//   Order(fGL)=6
//   Trace profile on V26 = [1,-1,-2]
//
// Warning:
//   fGL is in GL26(7), not yet proved to lie in F4(7).
///////////////////////////////////////////////////////////////

SetSeed(2);

F := GF(7);

function SignedGF7(a)
    a := F!a;
    if a eq F!0 then
        return 0;
    elif a eq F!1 then
        return 1;
    elif a eq F!2 then
        return 2;
    elif a eq F!3 then
        return 3;
    elif a eq F!4 then
        return -3;
    elif a eq F!5 then
        return -2;
    elif a eq F!6 then
        return -1;
    end if;
end function;

function TraceProfile(M)
    return [SignedGF7(Trace(M^i)) : i in [1..3]];
end function;

function DistinctMatrixCount(seq)
    reps := [];
    for X in seq do
        seen := false;
        for Y in reps do
            if X eq Y then
                seen := true;
                break;
            end if;
        end for;
        if not seen then
            Append(~reps, X);
        end if;
    end for;
    return #reps;
end function;

print "============================================================";
print "STEP 5D ALL-IN-ONE: CONTROLLED GL ORDER-6 TRANSPORTER";
print "============================================================";

print "Building G := ChevalleyGroup(\"F\",4,GF(7))...";
G := ChevalleyGroup("F", 4, F);

print "Degree =", Degree(G);
print "Base ring =", BaseRing(G);

///////////////////////////////////////////////////////////////
// Find g
///////////////////////////////////////////////////////////////

print "";
print "Finding g of order 13 with Trace(g)=0...";

foundG := false;
maxTrialsG := 500;

for trial in [1..maxTrialsG] do
    y := Random(G);
    oy := Order(y);

    if oy mod 13 eq 0 then
        gg := y^(oy div 13);

        if Order(gg) eq 13 and Trace(gg) eq F!0 then
            g := gg;
            foundG := true;

            print "SUCCESS: found g.";
            print "Trial =", trial;
            print "Original random element order =", oy;
            print "Order(g) =", Order(g);
            print "Trace(g) =", Trace(g);

            break;
        end if;
    end if;
end for;

if not foundG then
    error "No suitable g found.";
end if;

///////////////////////////////////////////////////////////////
// Build clean adapted basis 2 + 12 + 12
///////////////////////////////////////////////////////////////

d := Degree(G);
A := Matrix(g);
Id26 := IdentityMatrix(F, d);
V := VectorSpace(F, d);

print "";
print "Building clean 2+12+12 adapted basis...";

Kfix := Nullspace(A - Id26);
Wnon := RowSpace(A - Id26);

fixBasis := Basis(Kfix);
wBasis := Basis(Wnon);

print "dim Fix(g) =", Dimension(Kfix);
print "dim Wnon =", Dimension(Wnon);
print "dim Fix + Wnon =", Dimension(sub< V | fixBasis cat wBasis >);

if Dimension(Kfix) ne 2 or Dimension(Wnon) ne 24 then
    error "Unexpected Fix/Wnon dimensions.";
end if;

function CyclicRows(v, A, len)
    rows := [];
    w := v;
    for i in [0..len-1] do
        Append(~rows, w);
        w := w * A;
    end for;
    return rows;
end function;

currentRows := [fixBasis[i] : i in [1..#fixBasis]];
currentSpace := sub< V | currentRows >;

for blockNo in [1..2] do

    foundBlock := false;

    for trial in [1..1000] do
        v := Random(Wnon);
        cyc := CyclicRows(v, A, 12);
        C := sub< V | cyc >;

        if Dimension(C) eq 12 then
            invariantC := (cyc[12] * A) in C;
            testSpace := sub< V | currentRows cat cyc >;

            if invariantC and Dimension(testSpace) eq Dimension(currentSpace) + 12 then
                print "  Found 12D cyclic block", blockNo, "at trial", trial;

                currentRows := currentRows cat cyc;
                currentSpace := testSpace;

                foundBlock := true;
                break;
            end if;
        end if;
    end for;

    if not foundBlock then
        error "Failed to find cyclic block.";
    end if;
end for;

Trow := ZeroMatrix(F, 26, 26);

for i in [1..26] do
    for j in [1..26] do
        Trow[i,j] := currentRows[i][j];
    end for;
end for;

if Rank(Trow) ne 26 then
    error "Trow is not invertible.";
end if;

Tadapt := Trow;
Aadapt := Tadapt * A * Tadapt^-1;

print "Rank(Tadapt) =", Rank(Tadapt);

///////////////////////////////////////////////////////////////
// Check clean block form
///////////////////////////////////////////////////////////////

Afix := Submatrix(Aadapt, 1, 1, 2, 2);
A12a := Submatrix(Aadapt, 3, 3, 12, 12);
A12b := Submatrix(Aadapt, 15, 15, 12, 12);

cleanBlocks :=
    Afix eq IdentityMatrix(F, 2) and
    Submatrix(Aadapt, 1, 3, 2, 24) eq ZeroMatrix(F, 2, 24) and
    Submatrix(Aadapt, 3, 1, 24, 2) eq ZeroMatrix(F, 24, 2) and
    Submatrix(Aadapt, 3, 15, 12, 12) eq ZeroMatrix(F, 12, 12) and
    Submatrix(Aadapt, 15, 3, 12, 12) eq ZeroMatrix(F, 12, 12);

print "Clean block form?", cleanBlocks;
print "Order fixed block =", Order(Afix);
print "Order first 12 block =", Order(A12a);
print "Order second 12 block =", Order(A12b);

if not cleanBlocks then
    error "Adapted basis is not clean.";
end if;

///////////////////////////////////////////////////////////////
// Build Frobenius transporter on each 12D block
///////////////////////////////////////////////////////////////

function FrobeniusTransporterBlock(C, k)
    // C is a 12x12 cyclic block for g.
    // Return K satisfying:
    //     C*K = K*C^k
    //
    // We choose e1*K = e1.
    F := BaseRing(C);
    n := Nrows(C);

    entries := [];

    for i in [1..n] do
        Cp := C^(k*(i-1));
        for j in [1..n] do
            Append(~entries, Cp[1,j]);
        end for;
    end for;

    return Matrix(F, n, n, entries);
end function;

print "";
print "Constructing 12D Frobenius transporters for exponent k=10...";

K12a := FrobeniusTransporterBlock(A12a, 10);
K12b := FrobeniusTransporterBlock(A12b, 10);

print "Check A12a*K12a = K12a*A12a^10 ?", A12a*K12a eq K12a*A12a^10;
print "Check A12b*K12b = K12b*A12b^10 ?", A12b*K12b eq K12b*A12b^10;

print "Order(K12a) =", Order(K12a);
print "Order(K12b) =", Order(K12b);
print "Trace profile K12a =", TraceProfile(K12a);
print "Trace profile K12b =", TraceProfile(K12b);

///////////////////////////////////////////////////////////////
// Build 2D fixed block
///////////////////////////////////////////////////////////////

// In GF(7), 3 and 5 both have order 6.
// diag(3,5) has trace profile:
//   Tr = 3+5 = 8 = 1
//   Tr square = 2+4 = 6 = -1
//   Tr cube = 6+6 = 12 = 5 = -2

F2 := Matrix(F, 2, 2, [F!3, F!0,
                       F!0, F!5]);

print "";
print "Fixed 2D block F2:";
print F2;
print "Order(F2) =", Order(F2);
print "Trace profile F2 =", TraceProfile(F2);

///////////////////////////////////////////////////////////////
// Block diagonal construction
///////////////////////////////////////////////////////////////

function BlockDiag3(F, B0, B1, B2)
    n0 := Nrows(B0);
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    n := n0 + n1 + n2;

    M := ZeroMatrix(F, n, n);

    for i in [1..n0] do
        for j in [1..n0] do
            M[i,j] := B0[i,j];
        end for;
    end for;

    for i in [1..n1] do
        for j in [1..n1] do
            M[n0+i,n0+j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n0+n1+i,n0+n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

Fadapt := BlockDiag3(F, F2, K12a, K12b);

print "";
print "Testing controlled Fadapt in adapted basis...";

print "Aadapt*Fadapt = Fadapt*Aadapt^10 ?",
    Aadapt*Fadapt eq Fadapt*Aadapt^10;

print "Fadapt^-1*Aadapt*Fadapt = Aadapt^10 ?",
    Fadapt^-1 * Aadapt * Fadapt eq Aadapt^10;

print "Order(Fadapt) =", Order(Fadapt);
print "Trace profile Fadapt =", TraceProfile(Fadapt);

///////////////////////////////////////////////////////////////
// Convert back to original coordinates
///////////////////////////////////////////////////////////////

fGL := Tadapt^-1 * Fadapt * Tadapt;

print "";
print "Testing fGL in original V26 coordinates...";

print "A*fGL = fGL*A^10 ?", A*fGL eq fGL*A^10;
print "fGL^-1*A*fGL = A^10 ?", fGL^-1 * A * fGL eq A^10;
print "Order(fGL) =", Order(fGL);
print "Trace profile fGL =", TraceProfile(fGL);

///////////////////////////////////////////////////////////////
// Normal form count for <g,fGL>
///////////////////////////////////////////////////////////////

normalForms := [];

for i in [0..12] do
    for j in [0..5] do
        Append(~normalForms, A^i * fGL^j);
    end for;
end for;

nfCount := DistinctMatrixCount(normalForms);

print "";
print "Normal form count for <g,fGL>:";
print "# distinct A^i*fGL^j, 0<=i<13, 0<=j<6 =", nfCount;

print "";
print "STEP 5D SUMMARY:";

if A*fGL eq fGL*A^10 and Order(fGL) eq 6 and TraceProfile(fGL) eq [1,-1,-2] and nfCount eq 78 then
    print "SUCCESS: built controlled GL26 Walton local f.";
    print "We have:";
    print "  Order(g)=13";
    print "  Order(fGL)=6";
    print "  fGL^-1*g*fGL = g^10";
    print "  Trace profile on V26 = [1,-1,-2]";
    print "  Normal forms give |<g,fGL>| = 78";
    print "";
    print "Important: fGL is still only a GL26 matrix.";
    print "Next step: test whether fGL is actually compatible with genuine F4(7) structure.";
else
    print "Not fully successful. Send output before continuing.";
end if;
