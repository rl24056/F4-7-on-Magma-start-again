F := GF(7);

function SignedGF7(a)
    a := F!a;
    if a eq F!0 then
        return 0;
    elif a eq F!1 then
        return 1;
    elif a eq F!2 then
        return 2;
    elif a eq F!3 then
        return 3;
    elif a eq F!4 then
        return -3;
    elif a eq F!5 then
        return -2;
    elif a eq F!6 then
        return -1;
    end if;
end function;

function TraceProfileSmall(M)
    return [SignedGF7(Trace(M^i)) : i in [1..3]];
end function;

function BlockDiag3(F, B0, B1, B2)
    n0 := Nrows(B0);
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    n := n0 + n1 + n2;

    M := ZeroMatrix(F, n, n);

    for i in [1..n0] do
        for j in [1..n0] do
            M[i,j] := B0[i,j];
        end for;
    end for;

    for i in [1..n1] do
        for j in [1..n1] do
            M[n0+i,n0+j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n0+n1+i,n0+n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

procedure PrintBlockInfo(name, M)
    print name, ": size", Nrows(M), "x", Ncols(M),
          " rank =", Rank(M),
          " zero? ", M eq ZeroMatrix(BaseRing(M), Nrows(M), Ncols(M));
end procedure;

