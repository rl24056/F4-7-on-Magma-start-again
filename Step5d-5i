    elif a eq F!6 then
        return -1;
    end if;
end function;

function TraceProfile(M)
    return [SignedGF7(Trace(M^i)) : i in [1..3]];
end function;

function BlockDiag2(F, B1, B2)
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    M := ZeroMatrix(F, n1+n2, n1+n2);

    for i in [1..n1] do
        for j in [1..n1] do
            M[i,j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n1+i,n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

function BuildEquationMatrix(C, B)
    F := BaseRing(C);
    n := Nrows(C);
    rows := [];

    for i in [1..n] do
        for j in [1..n] do
            row := [F!0 : k in [1..n*n]];

            for a in [1..n] do
                idx := (a-1)*n + j;
                row[idx] +:= C[i,a];
            end for;

            for b in [1..n] do
                idx := (i-1)*n + b;
                row[idx] -:= B[b,j];
            end for;

            Append(~rows, row);
        end for;
    end for;

    return Matrix(F, rows);
end function;

function MatFromVec_ColMajor(v, n, F)
    s := Eltseq(v);
    return Matrix(F, n, n, [s[(j-1)*n + i] : i in [1..n], j in [1..n]]);
end function;

function ScalarMultipleInfo(X, Y, F)
    for lambda in F do
        if X eq lambda * Y then
            return true, lambda;
        end if;
    end for;

    return false, F!0;
end function;

function ScaleToExactForm(Y, S, F)
    // If Y*S*Y^T = lambda*S, try c*Y with c^2*lambda=1.
    Sf := Y*S*Transpose(Y);
    isScalar, lambda := ScalarMultipleInfo(Sf, S, F);

    if not isScalar or lambda eq F!0 then
        return false, Y, F!0, F!0;
    end if;

    for c in F do
        if c ne F!0 and c^2 * lambda eq F!1 then
            return true, c*Y, lambda, c;
        end if;
    end for;

    return false, Y, lambda, F!0;
end function;

