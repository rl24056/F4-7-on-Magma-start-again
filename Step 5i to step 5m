    print "  Tau(H11) = H11 ?", Tau(H11) eq H11;
    print "  Tau(H22) = H22 ?", Tau(H22) eq H22;
    print "  H21 = Tau(H12) ?", H21 eq Tau(H12);
    print "  H12 = Tau(H21) ?", H12 eq Tau(H21);

    print "";
