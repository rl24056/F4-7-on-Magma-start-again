    print "  Sigma(H11) =", Sigma(H11);
    print "  Sigma(H12) =", Sigma(H12);
    print "  Sigma(H21) =", Sigma(H21);
    print "  Sigma(H22) =", Sigma(H22);

    print "";
    print "Does Sigma fix H entrywise?";
    print "  Sigma(H11)=H11 ?", Sigma(H11) eq H11;
    print "  Sigma(H12)=H12 ?", Sigma(H12) eq H12;
    print "  Sigma(H21)=H21 ?", Sigma(H21) eq H21;
    print "  Sigma(H22)=H22 ?", Sigma(H22) eq H22;

    print "";
    print "NEXT:";
    print "Solve the semilinear isometry equation over E:";
    print "  M * Sigma(H) * Tau(Transpose(M)) = H";
    print "with M a 2x2 matrix over E.";
end if;
///////////////////////////////////////////////////////////////
// STEP 5J:
// Solve the E-level semilinear Hermitian isometry problem.
//
// Run after STEP 5I in the same Magma session.
//
// Assumes Step 5I has stored:
//   F, E, a, Tau, Sigma
//   H11,H12,H21,H22
//   Aadapt, Sadapt, Tadapt, Sbest, A
//
// Goal:
//   Solve over E:
//
//       M * Sigma(H) * TauTranspose(M) = H
//
//   Then convert M into a 24x24 GF(7)-matrix Y24 and test:
//
//       A24*Y24 = Y24*A24^10
//       Y24*S24*Transpose(Y24) = S24
//
//   Then combine with a 2D fixed block preserving S00.
///////////////////////////////////////////////////////////////

print "";
print "============================================================";
print "STEP 5J: SOLVE E-LEVEL SEMILINEAR HERMITIAN ISOMETRY";
print "============================================================";

if not assigned H11 then
    error "H11 is not assigned. Run Step 5I first.";
end if;

if not assigned Aadapt then
    error "Aadapt is not assigned. Run Step 5I first.";
end if;

if not assigned Sadapt then
    error "Sadapt is not assigned. Run Step 5I first.";
end if;

F := GF(7);

///////////////////////////////////////////////////////////////
// Helpers
///////////////////////////////////////////////////////////////

function SignedGF7(x)
    x := F!x;
    if x eq F!0 then
        return 0;
    elif x eq F!1 then
        return 1;
    elif x eq F!2 then
        return 2;
    elif x eq F!3 then
        return 3;
    elif x eq F!4 then
        return -3;
    elif x eq F!5 then
        return -2;
    elif x eq F!6 then
        return -1;
    end if;
end function;

function TraceProfile(M)
    return [SignedGF7(Trace(M^i)) : i in [1..3]];
end function;

function TauTranspose(M)
    R := ZeroMatrix(BaseRing(M), Ncols(M), Nrows(M));
    for i in [1..Nrows(M)] do
        for j in [1..Ncols(M)] do
            R[j,i] := Tau(M[i,j]);
        end for;
    end for;
    return R;
end function;

function SigmaMatrix(M)
    R := ZeroMatrix(BaseRing(M), Nrows(M), Ncols(M));
    for i in [1..Nrows(M)] do
        for j in [1..Ncols(M)] do
            R[i,j] := Sigma(M[i,j]);
        end for;
    end for;
    return R;
end function;

function HermitianValue(H, v, w)
    // v,w are length-2 sequences over E.
    s := BaseRing(H)!0;
    for i in [1..2] do
        for j in [1..2] do
            s +:= v[i] * H[i,j] * Tau(w[j]);
        end for;
    end for;
    return s;
end function;

function HermitianDiagonalise(H)
    E := BaseRing(H);

    candidates := [
        [E!1,E!0],
        [E!0,E!1],
        [E!1,E!1],
        [E!1,E.1],
        [E!1,E.1^2],
        [E!1,E.1^3],
        [E!1,E.1^4],
        [E!1,E.1^5]
    ];

    v := [E!0,E!0];
    qv := E!0;

    for cand in candidates do
        q := HermitianValue(H, cand, cand);
        if q ne E!0 then
            v := cand;
            qv := q;
            break;
        end if;
    end for;

    if qv eq E!0 then
        error "Failed to find non-isotropic vector.";
    end if;

    // Compute c = v*H
    c1 := v[1]*H[1,1] + v[2]*H[2,1];
    c2 := v[1]*H[1,2] + v[2]*H[2,2];

    if c1 eq E!0 and c2 eq E!0 then
        error "v*H is zero, impossible for nondegenerate H.";
    end if;

    // Pick w with <v,w>=0:
    // c1*Tau(w1)+c2*Tau(w2)=0.
    w := [Tau(c2), Tau(-c1)];

    qw := HermitianValue(H, w, w);

    if qw eq E!0 then
        error "Orthogonal complement vector has zero norm.";
    end if;

    P := Matrix(E, 2, 2, [v[1],v[2], w[1],w[2]]);
    D := P * H * TauTranspose(P);

    print "  diagonalisation check off-diagonal zero?",
        D[1,2] eq E!0 and D[2,1] eq E!0;

    return P, D;
end function;

function NormPreimage(n)
    // Solve r*Tau(r)=n in E.
    // Here Tau is z -> z^q with q=7^6, so Norm(r)=r^(q+1).
    E := Parent(n);
    q := 7^6;

    if n eq E!0 then
        return E!0;
    end if;

    z := PrimitiveElement(E);
    Nz := z^(q+1);

    pow := E!1;
    for m in [0..q-2] do
        if pow eq n then
            return z^m;
        end if;
        pow *:= Nz;
    end for;

    error "NormPreimage failed.";
end function;

function BlockDiag2(F, B1, B2)
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    M := ZeroMatrix(F, n1+n2, n1+n2);

    for i in [1..n1] do
        for j in [1..n1] do
            M[i,j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n1+i,n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

function Block2x2_12(F, B11, B12, B21, B22)
    M := ZeroMatrix(F, 24, 24);

    for i in [1..12] do
        for j in [1..12] do
            M[i,j] := B11[i,j];
            M[i,12+j] := B12[i,j];
            M[12+i,j] := B21[i,j];
            M[12+i,12+j] := B22[i,j];
        end for;
    end for;

    return M;
end function;

function Coeffs12(z)
    s := Eltseq(z);
    while #s lt 12 do
        Append(~s, F!0);
    end while;
    return [F!s[i] : i in [1..12]];
end function;

function SemiBlock(c)
    // 12x12 GF(7)-matrix for map z -> Sigma(z)*c
    M := ZeroMatrix(F, 12, 12);

    for i in [1..12] do
        z := a^(i-1);
        image := Sigma(z) * c;
        coeffs := Coeffs12(image);

        for j in [1..12] do
            M[i,j] := coeffs[j];
        end for;
    end for;

    return M;
end function;

function BuildY24FromM(ME, mode)
    // mode = 1: row convention blocks [[M11,M12],[M21,M22]]
    // mode = 2: transposed block convention [[M11,M21],[M12,M22]]

    B11 := SemiBlock(ME[1,1]);
    B12 := SemiBlock(ME[1,2]);
    B21 := SemiBlock(ME[2,1]);
    B22 := SemiBlock(ME[2,2]);

    if mode eq 1 then
        return Block2x2_12(F, B11, B12, B21, B22);
    elif mode eq 2 then
        return Block2x2_12(F, B11, B21, B12, B22);
    else
        error "Unknown BuildY24 mode.";
    end if;
end function;

///////////////////////////////////////////////////////////////
// Build H and Sigma(H)
///////////////////////////////////////////////////////////////

H := Matrix(E, 2, 2, [H11,H12,H21,H22]);
HSigma := SigmaMatrix(H);

print "H Hermitian?", TauTranspose(H) eq H;
print "HSigma Hermitian?", TauTranspose(HSigma) eq HSigma;

print "";
print "Diagonalising H...";
P1, D1 := HermitianDiagonalise(H);
print "D1 =";
print D1;

print "";
print "Diagonalising Sigma(H)...";
P2, D2 := HermitianDiagonalise(HSigma);
print "D2 =";
print D2;

///////////////////////////////////////////////////////////////
// Build R so R*D2*TauTranspose(R)=D1
///////////////////////////////////////////////////////////////

r1 := NormPreimage(D1[1,1] / D2[1,1]);
r2 := NormPreimage(D1[2,2] / D2[2,2]);

R := Matrix(E, 2, 2, [r1,E!0,E!0,r2]);

print "";
print "Norm checks:";
print "  r1*Tau(r1) = D1[1,1]/D2[1,1] ?",
    r1*Tau(r1) eq D1[1,1]/D2[1,1];
print "  r2*Tau(r2) = D1[2,2]/D2[2,2] ?",
    r2*Tau(r2) eq D1[2,2]/D2[2,2];

print "  R*D2*TauTranspose(R)=D1 ?",
    R*D2*TauTranspose(R) eq D1;

///////////////////////////////////////////////////////////////
// M solving M*Sigma(H)*TauTranspose(M)=H
///////////////////////////////////////////////////////////////

M := P1^-1 * R * P2;

print "";
print "Testing E-level solution:";
print "  M*Sigma(H)*TauTranspose(M)=H ?",
    M*HSigma*TauTranspose(M) eq H;

print "M =";
print M;

///////////////////////////////////////////////////////////////
// Convert to 24D GF(7) matrices and test both conventions
///////////////////////////////////////////////////////////////

A24 := Submatrix(Aadapt, 3, 3, 24, 24);
S24 := Submatrix(Sadapt, 3, 3, 24, 24);
S00 := Submatrix(Sadapt, 1, 1, 2, 2);

print "";
print "Testing converted 24D matrices...";

goodY := false;

candidateMs := [
    <"M", M>,
    <"Transpose(M)", Transpose(M)>,
    <"M^-1", M^-1>,
    <"TauTranspose(M)", TauTranspose(M)>,
    <"TauTranspose(M)^-1", TauTranspose(M)^-1>
];

for cand in candidateMs do
    label := cand[1];
    ME := cand[2];

    for mode in [1,2] do

        Y24 := BuildY24FromM(ME, mode);

        okTrans := A24*Y24 eq Y24*A24^10;
        okForm := Y24*S24*Transpose(Y24) eq S24;
        ordY := Order(Y24);
        profY := TraceProfile(Y24);

        print "";
        print "Candidate", label, "mode", mode;
        print "  transporter?", okTrans;
        print "  preserves S24?", okForm;
        print "  Order(Y24) =", ordY;
        print "  Trace profile =", profY;

        if okTrans and okForm then
            Y24good := Y24;
            goodY := true;
            print "  SUCCESS: this Y24 works for transporter and form.";
            break;
        end if;
    end for;

    if goodY then
        break;
    end if;
end for;

///////////////////////////////////////////////////////////////
// Find good 2D fixed block and combine
///////////////////////////////////////////////////////////////

fixedCandidates := [];

for a0 in F do
for b0 in F do
for c0 in F do
for d0 in F do

