    print "WARNING: cubic invariant space is not yet 1-dimensional.";
    print "Increase numRandomVectors, for example to 2200, and rerun Step 5L.";
else

    coeff := Basis(Kcub)[1];

    print "";
    print "Recovered a 1-dimensional candidate cubic invariant.";

    ///////////////////////////////////////////////////////////////
    // Sanity test on genuine F4 generators
    ///////////////////////////////////////////////////////////////

    print "";
    print "Sanity test: genuine generators preserve recovered cubic on random vectors.";

    genPass := true;

    for trial in [1..100] do
        v := Random(V);
        cv := EvalCubic(coeff, v, monoms);

        for M in gens do
            if EvalCubic(coeff, v*M, monoms) ne cv then
                genPass := false;
                print "  FAIL at trial", trial;
                break;
            end if;
        end for;

        if not genPass then
            break;
        end if;
    end for;

    print "Genuine generators pass random cubic test?", genPass;

    ///////////////////////////////////////////////////////////////
    // Test fHermGL
    ///////////////////////////////////////////////////////////////

    print "";
    print "Testing fHermGL on recovered cubic invariant...";

    fPass := true;
    failTrial := 0;

    for trial in [1..300] do
        v := Random(V);
        cv := EvalCubic(coeff, v, monoms);
        cfv := EvalCubic(coeff, v*fHermGL, monoms);

        if cfv ne cv then
            fPass := false;
            failTrial := trial;
            break;
        end if;
    end for;

    print "fHermGL preserves cubic on 300 random vectors?", fPass;

    print "";
    print "STEP 5L SUMMARY:";

    if genPass and fPass then
        print "SUCCESS: fHermGL passes the bilinear form and random cubic invariant tests.";
        print "This is strong evidence that fHermGL is genuinely F4-compatible.";
        print "Next step: build B=<g,fHermGL> and start the t-search, still avoiding direct membership.";
    elif genPass and not fPass then
        print "FAIL: fHermGL does not preserve the cubic invariant.";
        print "Then fHermGL is not in genuine F4(7), despite preserving the bilinear form.";
        print "Failure trial =", failTrial;
        print "Next step: impose cubic invariance while constructing f.";
    else
        print "The recovered cubic did not pass the generator sanity test.";
        print "Then the random equation recovery was not reliable; increase equations or adjust method.";
    end if;
end if;
