print "";
print "STEP 5I SUMMARY:";
print "Chosen trace-form variant =", chosenVariant;

if chosenVariant eq 0 then

    print "No variant reconstructed all four blocks.";
    print "This means the 12D cyclic bases are not yet matched to the simple E power basis.";
    print "Next step would add block-specific basis matching to the companion/power basis.";

else

