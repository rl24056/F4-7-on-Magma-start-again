///////////////////////////////////////////////////////////////
// STEP 5I ALL-IN-ONE:
//
// Fresh Magma Online version.
//
// Rebuild:
//   G := ChevalleyGroup("F",4,GF(7))
//   g order 13 trace 0
//   clean adapted basis V26 = 2 + 12 + 12
//   genuine F4-invariant bilinear form Sbest
//   Sadapt in the 2+12+12 basis
//
// Then recover the extension-field Hermitian form on the 24D part.
//
// Goal:
//   W24 = 12 + 12 should be viewed as E^2,
//   where E = GF(7^12).
//
//   Recover the 2x2 Hermitian matrix H over E representing S24.
//
// This prepares the deterministic solution of the 24D isometry problem.
///////////////////////////////////////////////////////////////

SetSeed(2);

F := GF(7);

print "============================================================";
print "STEP 5I ALL-IN-ONE: RECOVER E=GF(7^12) HERMITIAN FORM";
print "============================================================";

///////////////////////////////////////////////////////////////
// Basic helper functions
///////////////////////////////////////////////////////////////

function SignedGF7(a)
    a := F!a;
    if a eq F!0 then
        return 0;
    elif a eq F!1 then
        return 1;
    elif a eq F!2 then
        return 2;
    elif a eq F!3 then
        return 3;
    elif a eq F!4 then
        return -3;
    elif a eq F!5 then
        return -2;
    elif a eq F!6 then
        return -1;
    end if;
end function;

function CyclicRows(v, A, len)
    rows := [];
    w := v;
    for i in [0..len-1] do
        Append(~rows, w);
        w := w * A;
    end for;
    return rows;
end function;

function MatFromVec_RowMajor(v, d, F)
    s := Eltseq(v);
    return Matrix(F, d, d, [s[(i-1)*d + j] : i in [1..d], j in [1..d]]);
end function;

function InvariantBilinearFormSpace(mats, F, d)
    rows := [];

    for M in mats do
        for i in [1..d] do
            for j in [1..d] do

                row := [F!0 : n in [1..d*d]];

                // Equation:
                //   M*S*Transpose(M) - S = 0
                for a in [1..d] do
                    for b in [1..d] do
                        idx := (a-1)*d + b;
                        row[idx] +:= M[i,a] * M[j,b];
                    end for;
                end for;

                idx0 := (i-1)*d + j;
                row[idx0] -:= F!1;

                Append(~rows, row);
            end for;
        end for;
    end for;

    L := Matrix(F, rows);
    return Nullspace(Transpose(L));
end function;

function VecMat(M)
    return Vector(BaseRing(M), [M[i,j] : i in [1..Nrows(M)], j in [1..Ncols(M)]]);
end function;

///////////////////////////////////////////////////////////////
// Build genuine F4(7)
///////////////////////////////////////////////////////////////

print "";
print "Building G := ChevalleyGroup(\"F\",4,GF(7))...";
G := ChevalleyGroup("F", 4, F);

print "Degree =", Degree(G);
print "Base ring =", BaseRing(G);
print "Number of generators =", Ngens(G);

///////////////////////////////////////////////////////////////
// Find g
///////////////////////////////////////////////////////////////

print "";
print "Finding g of order 13 with Trace(g)=0...";

foundG := false;
maxTrialsG := 500;

for trial in [1..maxTrialsG] do
    y := Random(G);
    oy := Order(y);

    if oy mod 13 eq 0 then
        gg := y^(oy div 13);

        if Order(gg) eq 13 and Trace(gg) eq F!0 then
            g := gg;
            foundG := true;

            print "SUCCESS: found g.";
            print "Trial =", trial;
            print "Original random element order =", oy;
            print "Order(g) =", Order(g);
            print "Trace(g) =", Trace(g);
            print "Trace(g^i), i=1..12 =",
                [SignedGF7(Trace(g^i)) : i in [1..12]];

            break;
        end if;
    end if;
end for;

if not foundG then
    error "No suitable g found. Increase maxTrialsG.";
end if;

///////////////////////////////////////////////////////////////
// Build clean adapted basis V26 = 2 + 12 + 12
///////////////////////////////////////////////////////////////

print "";
print "Building clean adapted basis V26 = 2 + 12 + 12...";

d := Degree(G);
A := Matrix(g);
Id26 := IdentityMatrix(F, d);
V := VectorSpace(F, d);

Kfix := Nullspace(A - Id26);
Wnon := RowSpace(A - Id26);

fixBasis := Basis(Kfix);
wBasis := Basis(Wnon);

print "dim Fix(g) =", Dimension(Kfix);
print "dim Wnon =", Dimension(Wnon);
print "dim Fix + Wnon =", Dimension(sub< V | fixBasis cat wBasis >);

if Dimension(Kfix) ne 2 or Dimension(Wnon) ne 24 or
   Dimension(sub< V | fixBasis cat wBasis >) ne 26 then
    error "Unexpected Fix/Wnon decomposition.";
end if;

currentRows := [fixBasis[i] : i in [1..#fixBasis]];
currentSpace := sub< V | currentRows >;

for blockNo in [1..2] do

    foundBlock := false;

    for trial in [1..1000] do
        v := Random(Wnon);
        cyc := CyclicRows(v, A, 12);
        C := sub< V | cyc >;

        if Dimension(C) eq 12 then
            invariantC := (cyc[12] * A) in C;
            testSpace := sub< V | currentRows cat cyc >;

            if invariantC and Dimension(testSpace) eq Dimension(currentSpace) + 12 then

                print "  Found 12D cyclic block", blockNo, "at trial", trial;

                currentRows := currentRows cat cyc;
                currentSpace := testSpace;

                foundBlock := true;
                break;
            end if;
        end if;
    end for;

    if not foundBlock then
        error "Failed to find 12D cyclic block.";
    end if;
end for;

Tadapt := ZeroMatrix(F, 26, 26);

for i in [1..26] do
    for j in [1..26] do
        Tadapt[i,j] := currentRows[i][j];
    end for;
end for;

if Rank(Tadapt) ne 26 then
    error "Tadapt is not invertible.";
end if;

Aadapt := Tadapt * A * Tadapt^-1;

cleanBlocks :=
    Submatrix(Aadapt, 1, 1, 2, 2) eq IdentityMatrix(F, 2) and
    Submatrix(Aadapt, 1, 3, 2, 24) eq ZeroMatrix(F, 2, 24) and
    Submatrix(Aadapt, 3, 1, 24, 2) eq ZeroMatrix(F, 24, 2) and
    Submatrix(Aadapt, 3, 15, 12, 12) eq ZeroMatrix(F, 12, 12) and
    Submatrix(Aadapt, 15, 3, 12, 12) eq ZeroMatrix(F, 12, 12);

print "Rank(Tadapt) =", Rank(Tadapt);
print "Clean block form?", cleanBlocks;

if not cleanBlocks then
    error "Adapted basis is not clean.";
end if;

A12a := Submatrix(Aadapt, 3, 3, 12, 12);
A12b := Submatrix(Aadapt, 15, 15, 12, 12);

print "Order first 12 block =", Order(A12a);
print "Order second 12 block =", Order(A12b);

///////////////////////////////////////////////////////////////
// Compute genuine F4-invariant bilinear form Sbest
///////////////////////////////////////////////////////////////

print "";
print "Computing genuine F4-invariant bilinear form...";

gens := [Matrix(G.i) : i in [1..Ngens(G)]];
Kbil := InvariantBilinearFormSpace(gens, F, d);
Bbil := Basis(Kbil);

print "Dimension invariant bilinear form space =", Dimension(Kbil);

if Dimension(Kbil) eq 0 then
    error "No invariant bilinear form found.";
end if;

bestRank := -1;
Sbest := ZeroMatrix(F, d, d);

for r in [1..#Bbil] do
    S := MatFromVec_RowMajor(Bbil[r], d, F);
    rk := Rank(S);
    print "  basis form", r, "rank =", rk;

    if rk gt bestRank then
        bestRank := rk;
        Sbest := S;
    end if;
end for;

print "Selected Sbest rank =", Rank(Sbest);

if Rank(Sbest) ne 26 then
    error "Invariant form is singular.";
end if;

print "";
print "Sanity checks:";
for i in [1..Ngens(G)] do
    M := Matrix(G.i);
    print "  Generator", i, "preserves Sbest?",
        M*Sbest*Transpose(M) eq Sbest;
end for;

print "  g preserves Sbest?",
    A*Sbest*Transpose(A) eq Sbest;

///////////////////////////////////////////////////////////////
// Move form into adapted coordinates
///////////////////////////////////////////////////////////////

Sadapt := Tadapt * Sbest * Transpose(Tadapt);

print "";
print "Rank(Sadapt) =", Rank(Sadapt);
print "Aadapt preserves Sadapt?",
    Aadapt*Sadapt*Transpose(Aadapt) eq Sadapt;

///////////////////////////////////////////////////////////////
// Extract S24 blocks
///////////////////////////////////////////////////////////////

S11 := Submatrix(Sadapt, 3, 3, 12, 12);
S12 := Submatrix(Sadapt, 3, 15, 12, 12);
S21 := Submatrix(Sadapt, 15, 3, 12, 12);
S22 := Submatrix(Sadapt, 15, 15, 12, 12);

print "";
print "Ranks of 12x12 S24 blocks:";
print "  rank S11 =", Rank(S11);
print "  rank S12 =", Rank(S12);
print "  rank S21 =", Rank(S21);
print "  rank S22 =", Rank(S22);

///////////////////////////////////////////////////////////////
// Build E = GF(7^12)
///////////////////////////////////////////////////////////////

print "";
print "Building extension field E = GF(7^12)...";

P<x> := PolynomialRing(F);
Phi13 := &+[x^i : i in [0..12]];

E<a> := ext< F | Phi13 >;

print "Phi13 =", Phi13;
print "Degree(E/F) =", Degree(E);
print "Check a^13 = 1?", a^13 eq E!1;
print "Check a != 1?", a ne E!1;

function Tau(z)
    // Involution a -> a^-1.
    // Since 7^6 = -1 mod 13.
    return z^(7^6);
end function;

function Sigma(z)
    // Automorphism a -> a^10.
    // Since 7^2 = 10 mod 13.
    return z^(7^2);
end function;

print "Check Tau(a) = a^-1?", Tau(a) eq a^-1;
print "Check Sigma(a) = a^10?", Sigma(a) eq a^10;

///////////////////////////////////////////////////////////////
// Trace-form recovery
///////////////////////////////////////////////////////////////

function ETraceToF(z)
    return F!Trace(z);
end function;

function FormMatrixFromH(h, variant)
    M := ZeroMatrix(F, 12, 12);

    for i in [1..12] do
        xi := a^(i-1);

        for j in [1..12] do
            yj := a^(j-1);

            if variant eq 1 then
                val := h * xi * Tau(yj);
            elif variant eq 2 then
                val := h * yj * Tau(xi);
            elif variant eq 3 then
                val := h * Tau(xi) * yj;
            elif variant eq 4 then
                val := h * Tau(yj) * xi;
            else
                error "Unknown variant.";
            end if;

            M[i,j] := ETraceToF(val);
        end for;
    end for;

    return M;
end function;

function RecoverHFromBlock(Sblock, variant)
    forms := [];

    for r in [1..12] do
        hbasis := a^(r-1);
        Append(~forms, VecMat(FormMatrixFromH(hbasis, variant)));
    end for;

    Mlin := Matrix(F, 12, 144,
        [&cat[[forms[r][j] : j in [1..144]] : r in [1..12]]][1]);

    target := VecMat(Sblock);

    if not target in RowSpace(Mlin) then
        return E!0, false;
    end if;

    c := Solution(Mlin, target);

    h := E!0;
    for r in [1..12] do
        h +:= E!(c[r]) * a^(r-1);
    end for;

    recon := FormMatrixFromH(h, variant);

    return h, recon eq Sblock;
end function;

///////////////////////////////////////////////////////////////
// Try trace-form variants
///////////////////////////////////////////////////////////////

print "";
print "Trying to recover 2x2 Hermitian matrix H over E...";

chosenVariant := 0;

for variant in [1..4] do

    print "";
    print "Trying trace-form variant", variant;

    h11, ok11 := RecoverHFromBlock(S11, variant);
    h12, ok12 := RecoverHFromBlock(S12, variant);
    h21, ok21 := RecoverHFromBlock(S21, variant);
    h22, ok22 := RecoverHFromBlock(S22, variant);

    print "  reconstruct S11?", ok11;
    print "  reconstruct S12?", ok12;
    print "  reconstruct S21?", ok21;
    print "  reconstruct S22?", ok22;

    if ok11 and ok12 and ok21 and ok22 then
        chosenVariant := variant;

        H11 := h11;
        H12 := h12;
        H21 := h21;
        H22 := h22;

        print "  SUCCESS: variant", variant, "works for all blocks.";
        break;
    end if;
end for;

