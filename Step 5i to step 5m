///////////////////////////////////////////////////////////////
// Build degree-3 monomial index list
// Monomials are x_i x_j x_k with 1 <= i <= j <= k <= 26.
///////////////////////////////////////////////////////////////

monoms := [];

for i in [1..d] do
    for j in [i..d] do
        for k in [j..d] do
            Append(~monoms, <i,j,k>);
        end for;
    end for;
end for;

N := #monoms;

print "Number of cubic monomials =", N;

if N ne 3276 then
    error "Unexpected number of cubic monomials.";
end if;

function CubicMonomialValues(v, monoms)
    F := BaseRing(Parent(v));
    vals := [F!0 : m in [1..#monoms]];

    for n in [1..#monoms] do
        i := monoms[n][1];
        j := monoms[n][2];
        k := monoms[n][3];

        vals[n] := v[i] * v[j] * v[k];
    end for;

    return vals;
end function;

function EvalCubic(coeff, v, monoms)
    F := BaseRing(Parent(v));
    s := F!0;

    for n in [1..#monoms] do
        i := monoms[n][1];
        j := monoms[n][2];
        k := monoms[n][3];

        s +:= coeff[n] * v[i] * v[j] * v[k];
    end for;

    return s;
end function;

///////////////////////////////////////////////////////////////
// Build random equations C(v*M)-C(v)=0 for genuine generators
///////////////////////////////////////////////////////////////

V := VectorSpace(F, d);
gens := [Matrix(G.i) : i in [1..Ngens(G)]];

numRandomVectors := 1800;

print "";
print "Building random cubic invariant equations...";
print "Random vectors =", numRandomVectors;
print "Equations expected =", numRandomVectors * #gens;

rows := [];

for trial in [1..numRandomVectors] do

    v := Random(V);
    baseVals := CubicMonomialValues(v, monoms);

    for M in gens do
        w := v * M;
        wVals := CubicMonomialValues(w, monoms);

        row := [wVals[n] - baseVals[n] : n in [1..N]];
        Append(~rows, row);
    end for;

    if trial mod 100 eq 0 then
        print "  random vectors processed =", trial;
    end if;
end for;

L := Matrix(F, rows);

print "";
print "Equation matrix size =", Nrows(L), "x", Ncols(L);
print "Rank(L) =", Rank(L);

Kcub := Nullspace(Transpose(L));

print "Dimension of random cubic invariant candidate space =", Dimension(Kcub);

if Dimension(Kcub) eq 0 then
    error "No cubic invariant found. Something is wrong or equations too strong.";
end if;

