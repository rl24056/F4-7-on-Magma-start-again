function SignedGF7(x)
    x := F!x;
    if x eq F!0 then
        return 0;
    elif x eq F!1 then
        return 1;
    elif x eq F!2 then
        return 2;
    elif x eq F!3 then
        return 3;
    elif x eq F!4 then
        return -3;
    elif x eq F!5 then
        return -2;
    elif x eq F!6 then
        return -1;
    end if;
end function;

function TraceProfile(M)
    return [SignedGF7(Trace(M^i)) : i in [1..3]];
end function;

function EvalCubicLocal(coeff, v, monoms)
    s := F!0;

    for n in [1..#monoms] do
        i := monoms[n][1];
        j := monoms[n][2];
        k := monoms[n][3];

        s +:= coeff[n] * v[i] * v[j] * v[k];
    end for;

    return s;
end function;

function BlockDiag2(F, B1, B2)
    n1 := Nrows(B1);
    n2 := Nrows(B2);
    M := ZeroMatrix(F, n1+n2, n1+n2);

    for i in [1..n1] do
        for j in [1..n1] do
            M[i,j] := B1[i,j];
        end for;
    end for;

    for i in [1..n2] do
        for j in [1..n2] do
            M[n1+i,n1+j] := B2[i,j];
        end for;
    end for;

    return M;
end function;

function CubicPassesRandom(M, coeff, monoms, V, trials)
    for trial in [1..trials] do
        v := Random(V);
        cv := EvalCubicLocal(coeff, v, monoms);
        cw := EvalCubicLocal(coeff, v*M, monoms);

        if cw ne cv then
            return false, trial, cv, cw;
        end if;
    end for;

    return true, 0, F!0, F!0;
end function;

